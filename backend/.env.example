APP_NAME=学院学生综合服务与党团管理平台
APP_ENV=production
DATABASE_URL=postgresql+psycopg://student_service:student_service@127.0.0.1:5432/student_service
CORS_ORIGINS=http://10.10.0.21,http://127.0.0.1:5177
AUTO_CREATE_TABLES=false
AUTH_MODE=token
AUTH_SECRET=change-me-to-a-long-random-secret
AUTH_TOKEN_HOURS=12
UPLOAD_DIR=backend/storage/uploads
MAX_UPLOAD_BYTES=31457280
ENABLE_SCHEDULER=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
THEORY_QUESTION_COUNT=5
